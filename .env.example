# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5343/budget_forecasting

# ============================================
# API Configuration
# ============================================
API_TITLE=Budget Forecasting API
API_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ============================================
# Security
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# File Upload
# ============================================
UPLOAD_DIR=backend/data/uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_EXTENSIONS=xlsx,csv

# ============================================
# ML Models
# ============================================
MODEL_STORAGE_PATH=backend/data/models

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
